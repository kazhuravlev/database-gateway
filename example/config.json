{
	"targets": [
		{
			"id": "local-1",
			"description": "Production for clients service",
			"tags": [
				"env:production",
				"svc:clients",
				"replica:analytics"
			],
			"type": "postgres",
			"connection": {
				"host": "postgres1",
				"port": 5432,
				"user": "pg01",
				"password": "pg01",
				"db": "pg01",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.clients",
					"fields": [
						"id",
						"name",
						"email"
					]
				},
				{
					"table": "public.another_table",
					"fields": [
						"name",
						"surname",
						"money"
					]
				}
			]
		},
		{
			"id": "local-2",
			"description": "Another server",
			"tags": [
				"env:staging",
				"svc:clients"
			],
			"type": "postgres",
			"connection": {
				"host": "postgres2",
				"port": 5432,
				"user": "pg02",
				"password": "pg02",
				"db": "pg02",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.clients",
					"fields": [
						"id",
						"name",
						"email"
					]
				}
			]
		},
		{
			"id": "local-3",
			"description": "Experiments for John Doe",
			"tags": [
				"env:dev",
				"backup:never"
			],
			"type": "postgres",
			"connection": {
				"host": "postgres3",
				"port": 5432,
				"user": "pg03",
				"password": "pg03",
				"db": "pg03",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.clients",
					"fields": [
						"id",
						"name",
						"email"
					]
				}
			]
		}
	],
	"users": {
		"client_id": "db-gateway",
		"client_secret": "db-gateway-secret",
		"issuer_url": "http://authentik-server:9000/application/o/db-gateway/",
		"redirect_url": "http://localhost:8080/auth/callback",
		"access_token_audience": "db-gateway",
		"scopes": [
			"groups",
			"email",
			"profile"
		],
		"role_claim": "groups",
		"role_mapping": {
			"dbgw-admins": "admin",
			"dbgw-users": "user"
		}
	},
	"policy": {
		"path": "./opa/basic"
	},
	"facade": {
		"port": 8080,
		"cookie_secret": "secret",
		"unsafe_cors_allow_all": false
	},
	"storage": {
		"host": "storage-postgres",
		"port": 5432,
		"database": "local__dbgw",
		"username": "local__dbgw",
		"password": "local__dbgw",
		"use_ssl": false,
		"max_pool_size": 16
	}
}
