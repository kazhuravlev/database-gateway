{
	"targets": [
		{
			"id": "taxi-prod",
			"description": "Taxi svc database. Clients, drivers, transfers, etc.",
			"tags": [
				"env:production",
				"svc:taxi"
			],
			"type": "postgres",
			"connection": {
				"host": "127.0.0.1",
				"port": 5433,
				"user": "pgtaxi",
				"password": "pgtaxi",
				"db": "pgtaxi",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.clients",
					"fields": [
						"id",
						"full_name",
						"rating",
						"joined_at"
					]
				},
				{
					"table": "public.cars",
					"fields": [
						"id",
						"plate_number",
						"model",
						"color",
						"year_made",
						"service_status",
						"current_city"
					]
				},
				{
					"table": "public.drivers",
					"fields": [
						"id",
						"full_name",
						"phone",
						"rating",
						"status",
						"city",
						"car_id"
					]
				},
				{
					"table": "public.transfers",
					"fields": [
						"id",
						"client_id",
						"driver_id",
						"car_id",
						"pickup_address",
						"dropoff_address",
						"requested_at",
						"completed_at",
						"distance_km",
						"duration_minutes",
						"status",
						"fare_amount_cents"
					]
				},
				{
					"table": "public.transactions",
					"fields": [
						"id",
						"transfer_id",
						"payment_method",
						"amount_cents",
						"currency",
						"status",
						"processed_at",
						"external_reference"
					]
				}
			]
		},
		{
			"id": "pg-5434",
			"description": "Staging for clients service",
			"tags": [
				"env:staging",
				"svc:clients",
				"backup:each-night"
			],
			"type": "postgres",
			"connection": {
				"host": "127.0.0.1",
				"port": 5434,
				"user": "pg5434",
				"password": "pg5434",
				"db": "pg5434",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.clients",
					"fields": [
						"id",
						"name",
						"email"
					]
				}
			]
		},
		{
			"id": "pg-5435",
			"description": "Test server for John Doe experiments",
			"tags": [
				"env:dev",
				"owner:john.doe",
				"backup:never"
			],
			"type": "postgres",
			"connection": {
				"host": "127.0.0.1",
				"port": 5435,
				"user": "pg5435",
				"password": "pg5435",
				"db": "pg5435",
				"use_ssl": false,
				"max_pool_size": 4
			},
			"default_schema": "public",
			"tables": [
				{
					"table": "public.sales_olap_42",
					"fields": [
						"region_id",
						"month",
						"product_category",
						"total_sales",
						"total_quantity",
						"avg_sale_price"
					]
				}
			]
		}
	],
	"users": {
		"client_id": "db-gateway",
		"client_secret": "db-gateway-secret",
		"issuer_url": "http://localhost:9000/application/o/db-gateway/",
		"redirect_url": "http://localhost:8080/auth/callback",
		"access_token_audience": "db-gateway",
		"scopes": [
			"groups",
			"email",
			"profile"
		],
		"role_claim": "groups",
		"role_mapping": {
			"dbgw-admins": "admin",
			"dbgw-users": "user"
		}
	},
	"acls": [
		{
			"user": "user:admin@example.com",
			"op": "*",
			"target": "*",
			"tbl": "*",
			"allow": true
		},
		{
			"user": "role:user",
			"op": "*",
			"target": "pg-5433",
			"tbl": "*",
			"allow": true
		},
		{
			"user": "role:user",
			"op": "select",
			"target": "pg-5434",
			"tbl": "*",
			"allow": true
		}
	],
	"facade": {
		"port": 8080,
		"cookie_secret": "secret",
		"unsafe_cors_allow_all": true
	},
	"storage": {
		"host": "127.0.0.1",
		"port": 5432,
		"database": "local__dbgw",
		"username": "local__dbgw",
		"password": "local__dbgw",
		"use_ssl": false,
		"max_pool_size": 16
	}
}
